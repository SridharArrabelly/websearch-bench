# Azure AI Foundry project endpoint
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>

# Model deployment name in the Foundry project (used by all Foundry / Agent
# Framework backends). Keep the same model across backends so the comparison
# stays apples-to-apples.
MODEL=gpt-5.1

# Non-reasoning model used by the foundry-ws-bing-fast backend (must also be
# deployed in your Foundry project). Default tracks the model the South Africa
# PTU customer is pinned to.
MODEL_FAST=gpt-4o

# Allowed domains for web-search filtering. Comma-separated. Full URLs are
# accepted and normalized to hostnames (e.g. https://www.sars.gov.za/ ->
# www.sars.gov.za). Honored by foundry-ws-bing, foundry-ws-bing-fast, and
# agentfx-bing*. For foundry-ws-bingcustom and foundry-bing-grounding-custom,
# the allowed-domain list is configured on the Bing Custom Search *instance*
# in https://www.customsearch.ai/ instead.
ALLOWED_DOMAINS=https://www.sars.gov.za/

# Bing Grounding (legacy single-shot) — friendly connection name on the project
BING_CONNECTION_NAME=<your-bing-grounding-connection-name>

# Bing Custom Search — used by:
#   foundry-bing-grounding-custom (legacy BingCustomSearchPreviewTool)
#   foundry-ws-bingcustom         (new WebSearchTool variant)
# Both use the full ARM connection ID + the instance name.
BING_CUSTOM_SEARCH_CONNECTION_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<resource>/projects/<project>/connections/<connection-name>
BING_CUSTOM_SEARCH_INSTANCE_NAME=<custom-search-instance-name>

# Optional: Application Insights for distributed tracing + true Bing fan-out
# reconciliation. The harness queries the chat span after every Foundry run to
# overwrite the lower-bound bing_queries with the real count (see README).
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Optional: Redis (for agentfx-bing-cached)
REDIS_URL=redis://localhost:6379
CACHE_TTL_HOURS=24

# Optional: pricing overrides (USD per 1,000 calls). See pricing.py.
# WebSearchTool and BingGroundingTool both bill at the Grounding-with-Bing
# rate; the WebSearchTool charge appears on the Foundry / Cognitive Services
# account bill rather than the user's Microsoft.Bing/accounts resource.
# BING_GROUNDING_USD_PER_1K=35
# BING_CUSTOM_USD_PER_1K=35

# Optional: validate real Bing call counts via Azure Monitor metrics
# (use `uv run python -m websearch_bench.bing_usage --since 30m`).
# AZURE_SUBSCRIPTION_ID is required; the *_RESOURCE_ID vars are optional —
# if unset, the script auto-discovers Microsoft.Bing/accounts via the Azure CLI.
# AZURE_SUBSCRIPTION_ID=<subscription-id>
# BING_GROUNDING_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Bing/accounts/<name>
# BING_CUSTOM_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Bing/accounts/<name>

# Backend toggles — every backend is on by default; set to 0 to skip.
# ENABLE_FOUNDRY_BING_GROUNDING=1
# ENABLE_FOUNDRY_BING_GROUNDING_CUSTOM=1
# ENABLE_FOUNDRY_WS_BING=1
# ENABLE_FOUNDRY_WS_BING_FAST=1
# ENABLE_FOUNDRY_WS_BINGCUSTOM=1
# ENABLE_AGENTFX_BING=1
# ENABLE_AGENTFX_BING_CACHED=1
