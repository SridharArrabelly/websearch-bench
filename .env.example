# Azure AI Foundry project endpoint
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>

# Model deployment name in the Foundry project (used by all Foundry/AgentFx backends)
MODEL=gpt-5.1

# Model used by the OpenAI-direct backend (must be available on your OpenAI account)
OPENAI_MODEL=gpt-5.1

# Bing Custom Search — full ARM connection ID + instance name
BING_CUSTOM_SEARCH_CONNECTION_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<resource>/projects/<project>/connections/<connection-name>
BING_CUSTOM_SEARCH_INSTANCE_NAME=<custom-search-instance-name>

# OpenAI direct (only for the openai-web-search backend)
OPENAI_API_KEY=sk-...

# Optional: Application Insights for tracing in agentfx-bing-cached
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Optional: Redis (for agentfx-bing-cached)
REDIS_URL=redis://localhost:6379
CACHE_TTL_HOURS=24

# Optional: pricing overrides (USD per call). See src/websearch_bench/pricing.py.
# BING_GROUNDING_USD_PER_CALL=0.035
# BING_CUSTOM_USD_PER_CALL=0.025
# OPENAI_WEB_SEARCH_USD_PER_CALL=0.030
